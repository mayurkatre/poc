# Copy this file to .env and fill in your values
# cp .env.example .env

# --- OpenRouter (drop-in OpenAI replacement) ---
# Get your key at: https://openrouter.ai/keys
OPENAI_API_KEY=sk-or-v1-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
OPENAI_BASE_URL=https://openrouter.ai/api/v1

# Optional: shown in OpenRouter dashboard for usage tracking
OPENROUTER_APP_URL=https://github.com/your-username/rag-poc
OPENROUTER_APP_TITLE=RAG POC

# --- LangSmith (optional observability) ---
LANGCHAIN_API_KEY=ls__...
LANGCHAIN_TRACING_V2=false
LANGCHAIN_PROJECT=rag-poc

# --- App ---
RAG_CONFIG_PATH=config/settings.yaml
RAG_LOG_LEVEL=INFO
